{
  "functions": {
    "api/index.php": {
      "runtime": "vercel-php@0.9.0",
      "memory": 512,
      "maxDuration": 30
    }
  },
  "routes": [
    { "src": "/assets/(.*)", "dest": "/assets/$1" },
    { "src": "/favicon\\.ico", "dest": "/favicon.ico" },
    { "src": "/(.*)", "dest": "/api/index.php" }
  ]
}
